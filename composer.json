{
    "name": "rllngr/kirby-thumbzer",
    "description": "Kirby plugin — responsive srcset images with pre-generated thumbnails and ICC profile preservation",
    "keywords": ["kirby", "kirby-plugin", "srcset", "thumbnails", "webp", "icc", "responsive-images"],
    "type": "kirby-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Nicolas Rollinger",
            "email": "contact@rollinger.design",
            "homepage": "https://rollinger.design",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/RLLNGR/kirby-thumbzer",
    "support": {
        "source": "https://github.com/RLLNGR/kirby-thumbzer",
        "issues": "https://github.com/RLLNGR/kirby-thumbzer/issues"
    },
    "require": {
        "php": ">=8.0",
        "getkirby/composer-installer": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "Rllngr\\Thumbzer\\": "classes/"
        }
    },
    "extra": {
        "installer-name": "kirby-thumbzer"
    }
}
